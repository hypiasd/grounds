---
import { getCollection } from 'astro:content'
import GraphView from '../components/GraphView.astro'
import Search from '../components/Search.jsx'
import '../styles/global.css'

const notes = await getCollection('notes')
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const topics = new Map<string, typeof notes>()
for (const note of notes) {
  const topic = note.id.split('/')[0]
  if (!topics.has(topic)) topics.set(topic, [])
  topics.get(topic)!.push(note)
}

const recent = [...notes]
  .filter(n => !n.id.endsWith('/_overview'))
  .sort((a, b) => String(b.data.updated || '').localeCompare(String(a.data.updated || '')))
  .slice(0, 5)

function noteUrl(noteId: string): string {
  const isOverview = noteId.endsWith('/_overview')
  const slug = isOverview ? noteId.replace('/_overview', '') : noteId
  return `${base}/${slug}`
}
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>grounds</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href={base}>grounds</a>
  </header>

  <main style="max-width: 960px;">
    <p class="home-intro">个人学习笔记 · {notes.filter(n => !n.id.endsWith('/_overview')).length} 篇 · {topics.size} 个主题</p>

    <section class="home-section">
      <h2>知识图谱</h2>
      <GraphView height={400} />
    </section>

    <section class="home-section">
      <h2>主题</h2>
      <div class="topic-grid">
        {[...topics.entries()].map(([topic, topicNotes]) => {
          const overview = topicNotes.find(n => n.id.endsWith('/_overview'))
          const noteCount = topicNotes.filter(n => !n.id.endsWith('/_overview')).length
          return (
            <a class="topic-card" href={overview ? noteUrl(overview.id) : '#'}>
              <div class="topic-name">{topic}</div>
              <div class="topic-count">{noteCount} 篇笔记</div>
            </a>
          )
        })}
      </div>
    </section>

    <section class="home-section">
      <h2>最近更新</h2>
      <ul class="recent-list">
        {recent.map(note => (
          <li>
            <a href={noteUrl(note.id)}>{note.data.title || note.id}</a>
            <span class="meta">{note.data.topic} · {String(note.data.updated || '').slice(0, 10)}</span>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Search client:idle />
</body>
</html>
