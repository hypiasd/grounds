---
import { getCollection } from 'astro:content'
import GraphView from '../components/GraphView.astro'
import Sidebar from '../components/Sidebar.astro'
import SidebarToggle from '../components/SidebarToggle.astro'
import Search from '../components/Search.jsx'
import '../styles/global.css'

const notes = await getCollection('notes')
const papers = await getCollection('papers')
const videos = await getCollection('videos')
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const paperBase = `${base}/paper`
const videoBase = `${base}/video`

const topics = new Map<string, typeof notes>()
for (const note of notes) {
  const topic = note.id.split('/')[0]
  if (!topics.has(topic)) topics.set(topic, [])
  topics.get(topic)!.push(note)
}

const recent = [...notes]
  .filter(n => !n.id.endsWith('/_overview'))
  .sort((a, b) => String(b.data.updated || '').localeCompare(String(a.data.updated || '')))
  .slice(0, 5)

// 最近 5 篇论文
const recentPapers = [...papers]
  .filter(p => !p.id.endsWith('/_overview'))
  .sort((a, b) => String(b.data.updated || '').localeCompare(String(a.data.updated || '')))
  .slice(0, 5)

// 最近 5 个视频（按目录名去重）
const videoMap = new Map<string, typeof videos>()
for (const v of videos) {
  const slug = v.id.split('/')[0]
  if (!videoMap.has(slug)) videoMap.set(slug, v)
}
const recentVideos = [...videoMap.entries()]
  .map(([slug, v]) => ({ slug, video: v }))
  .sort((a, b) => String(b.video.data.updated || '').localeCompare(String(a.video.data.updated || '')))
  .slice(0, 5)

const noteCount = notes.filter(n => !n.id.endsWith('/_overview')).length
const paperCount = recentPapers.length
const videoCount = videoMap.size

function noteUrl(noteId: string): string {
  const isOverview = noteId.endsWith('/_overview')
  const slug = isOverview ? noteId.replace('/_overview', '') : noteId
  return `${base}/${slug}`
}

function paperUrl(paperId: string): string {
  const isOverview = paperId.endsWith('/_overview')
  const slug = isOverview ? paperId.replace('/_overview', '') : paperId
  return `${paperBase}/${slug}`
}
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>grounds</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <SidebarToggle />
  <header class="site-header">
    <a href={base}>grounds</a>
  </header>

  <div class="note-layout note-layout--topic">
    <Sidebar section="wiki" />

    <main class="note-main">
      <p class="home-intro">
        个人学习笔记 · {noteCount} 篇 wiki · {topics.size} 个主题
        {paperCount > 0 && ` · ${paperCount} 篇论文`}
        {videoCount > 0 && ` · ${videoCount} 个视频`}
      </p>

      <section class="home-section">
        <h2>最近更新</h2>
        <ul class="recent-list">
          {recent.map(note => (
            <li>
              <a href={noteUrl(note.id)}>{note.data.title || note.id}</a>
              <span class="meta">{note.data.topic} · {String(note.data.updated || '').slice(0, 10)}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="home-section">
        <h2>知识图谱</h2>
        <GraphView height={400} />
      </section>

      <section class="home-section">
        <h2>主题</h2>
        <div class="topic-grid">
          {[...topics.entries()].map(([topic, topicNotes]) => {
            const overview = topicNotes.find(n => n.id.endsWith('/_overview'))
            const noteCount = topicNotes.filter(n => !n.id.endsWith('/_overview')).length
            return (
              <a class="topic-card" href={overview ? noteUrl(overview.id) : '#'}>
                <div class="topic-name">{topic}</div>
                <div class="topic-count">{noteCount} 篇笔记</div>
              </a>
            )
          })}
        </div>
      </section>

      {paperCount > 0 && (
        <section class="home-section">
          <h2>论文笔记</h2>
          <ul class="recent-list">
            {recentPapers.map(paper => (
              <li>
                <a href={paperUrl(paper.id)}>{paper.data.title || paper.id}</a>
                <span class="meta">{paper.data.topic} · {String(paper.data.updated || '').slice(0, 10)}</span>
              </li>
            ))}
          </ul>
          <a class="section-more" href={`${paperBase}`}>查看全部 →</a>
        </section>
      )}

      {paperCount === 0 && (
        <section class="home-section">
          <h2>论文笔记</h2>
          <p class="empty-hint">还没有论文笔记。用 <code>$paper-learn &lt;arxiv-url&gt;</code> 开始读第一篇。</p>
        </section>
      )}

      {videoCount > 0 && (
        <section class="home-section">
          <h2>视频笔记</h2>
          <ul class="recent-list">
            {recentVideos.map(({ slug, video }) => (
              <li>
                <a href={`${videoBase}/${slug}`}>{video.data.title || slug}</a>
                <span class="meta">
                  {video.data.video_channel || ''}
                  {video.data.video_channel && video.data.video_duration && ' · '}
                  {video.data.video_duration || ''}
                  {` · ${String(video.data.updated || '').slice(0, 10)}`}
                </span>
              </li>
            ))}
          </ul>
          <a class="section-more" href={`${videoBase}`}>查看全部 →</a>
        </section>
      )}

      {videoCount === 0 && (
        <section class="home-section">
          <h2>视频笔记</h2>
          <p class="empty-hint">还没有视频笔记。用 <code>$bilibili-render-pdf &lt;BV链接&gt;</code> 或 <code>$youtube-render-pdf &lt;链接&gt;</code> 开始处理第一个视频。</p>
        </section>
      )}
    </main>
  </div>

  <Search client:idle />
</body>
</html>

<style>
  .empty-hint {
    color: var(--text-muted);
    margin: 16px 0;
    font-size: 14px;
  }
  .empty-hint code {
    background: var(--bg-sidebar);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
  }
  .section-more {
    display: inline-block;
    margin-top: 12px;
    color: var(--accent);
    text-decoration: none;
    font-size: 14px;
  }
  .section-more:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
</style>
