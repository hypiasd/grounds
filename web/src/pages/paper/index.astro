---
import { getCollection } from 'astro:content'
import Sidebar from '../../components/Sidebar.astro'
import SidebarToggle from '../../components/SidebarToggle.astro'
import Search from '../../components/Search.jsx'
import '../../styles/global.css'

const papers = await getCollection('papers')
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const paperBase = `${base}/paper`

const topics = new Map<string, typeof papers>()
for (const paper of papers) {
  const topic = paper.id.split('/')[0]
  if (!topics.has(topic)) topics.set(topic, [])
  topics.get(topic)!.push(paper)
}

function paperUrl(paperId: string): string {
  const isOverview = paperId.endsWith('/_overview')
  const slug = isOverview ? paperId.replace('/_overview', '') : paperId
  return `${paperBase}/${slug}`
}
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>论文笔记 · grounds</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <SidebarToggle />
  <header class="site-header">
    <a href={base}>grounds</a>
    <span style="margin-left: 16px; color: var(--text-muted);">/</span>
    <span style="margin-left: 8px;">paper</span>
  </header>

  <div class="note-layout note-layout--topic">
    <Sidebar section="paper" />

    <main class="note-main">
      <p class="home-intro">论文笔记 · {papers.filter(p => !p.id.endsWith('/_overview')).length} 篇 · {topics.size} 个主题</p>

      {topics.size === 0 ? (
        <p style="color: var(--text-muted); margin-top: 40px;">还没有论文笔记。用 <code>$paper-learn &lt;arxiv-url&gt;</code> 开始读第一篇。</p>
      ) : (
        <section class="home-section">
          <h2>主题</h2>
          <div class="topic-grid">
            {[...topics.entries()].map(([topic, topicPapers]) => {
              const overview = topicPapers.find(p => p.id.endsWith('/_overview'))
              const count = topicPapers.filter(p => !p.id.endsWith('/_overview')).length
              return (
                <a class="topic-card" href={overview ? paperUrl(overview.id) : '#'}>
                  <div class="topic-name">{topic}</div>
                  <div class="topic-count">{count} 篇论文</div>
                </a>
              )
            })}
          </div>
        </section>
      )}
    </main>
  </div>

  <Search client:idle />
</body>
</html>
