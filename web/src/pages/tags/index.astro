---
import { getCollection } from 'astro:content'
import '../../styles/global.css'

const notes = await getCollection('notes')
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// 聚合 tag
const tagCount = new Map<string, number>()
for (const note of notes) {
  for (const tag of note.data.tags || []) {
    tagCount.set(tag, (tagCount.get(tag) || 0) + 1)
  }
}

// 按计数倒序
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1])
const maxCount = tags[0]?.[1] || 1

// 字号映射
function fontSize(count: number): string {
  const ratio = count / maxCount
  const size = 0.85 + ratio * 0.9 // 0.85rem - 1.75rem
  return `${size}rem`
}
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>标签 · grounds</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href={base}>← grounds</a>
  </header>

  <main>
    <h1>标签</h1>
    <p class="home-intro">{tags.length} 个标签</p>

    <div class="tag-cloud" style="margin-top: 2em; line-height: 2.2;">
      {tags.map(([tag, count]) => (
        <a href={`${base}/tags/${tag}`} style={`font-size: ${fontSize(count)}; margin-right: 12px; color: var(--accent); text-decoration: none;`}>
          #{tag} <span style="color: var(--text-muted); font-size: 0.8em;">({count})</span>
        </a>
      ))}
    </div>
  </main>
</body>
</html>
