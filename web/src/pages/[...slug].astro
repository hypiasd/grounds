---
import { getCollection } from 'astro:content'
import Note from '../layouts/Note.astro'
import Topic from '../layouts/Topic.astro'

export async function getStaticPaths() {
  const notes = await getCollection('notes')
  return notes.map(note => {
    const isOverview = note.id.endsWith('/_overview')
    // _overview 渲染到 /<topic>，普通笔记渲染到 /<topic>/<note>
    const slug = isOverview ? note.id.replace('/_overview', '') : note.id
    return {
      params: { slug },
      props: { note },
    }
  })
}

const { note } = Astro.props
const isOverview = note.id.endsWith('/_overview')
---
{isOverview ? <Topic note={note} /> : <Note note={note} />}
