---
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const notes = await getCollection('notes')
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }))
}

const { note } = Astro.props
const { Content } = await render(note)
const data = note.data
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{data.title || note.id}</title>
</head>
<body>
  <p><a href={base}>← grounds</a></p>
  <h1>{data.title || note.id}</h1>
  {data.topic && (
    <p style="color: #888; font-size: 0.9em;">
      {data.topic}
      {data.updated && ` · ${data.updated}`}
      {data.tags && data.tags.length > 0 && ` · #${data.tags.join(' #')}`}
    </p>
  )}
  {data.summary && <p style="background: #f5f5f5; padding: 8px 12px; border-radius: 4px;">{data.summary}</p>}
  <article>
    <Content />
  </article>
</body>
</html>
