---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import '../styles/global.css'

interface Props {
  note: CollectionEntry<'notes'>
}

const { note } = Astro.props
const { Content } = await render(note)
const data = note.data
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// 同 topic 内 prev/next（按文件名字母序）
const allNotes = await getCollection('notes')
const topicNotes = allNotes
  .filter(n => n.id.startsWith(`${data.topic}/`) && !n.id.endsWith('/_overview'))
  .sort((a, b) => a.id.localeCompare(b.id))
const idx = topicNotes.findIndex(n => n.id === note.id)
const prev = idx > 0 ? topicNotes[idx - 1] : null
const next = idx >= 0 && idx < topicNotes.length - 1 ? topicNotes[idx + 1] : null

const updated = data.updated ? String(data.updated).slice(0, 10) : ''
const tags = data.tags || []
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{data.title || note.id}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href={base}>← grounds</a>
  </header>

  <main>
    <h1>{data.title || note.id}</h1>
    <div class="note-meta">
      {data.topic}
      {updated && ` · ${updated}`}
      {tags.map(t => <span class="tag">#{t}</span>)}
    </div>
    {data.summary && <div class="note-summary">{data.summary}</div>}

    <article>
      <Content />
    </article>

    <nav class="prev-next">
      {prev ? <a href={`${base}/${prev.id}`}>← {prev.data.title}</a> : <span />}
      {next ? <a href={`${base}/${next.id}`}>{next.data.title} →</a> : <span />}
    </nav>
  </main>
</body>
</html>
