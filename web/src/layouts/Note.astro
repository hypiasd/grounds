---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

interface Props {
  note: CollectionEntry<'notes'>
}

const { note } = Astro.props
const { Content } = await render(note)
const data = note.data
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// 同 topic 内 prev/next（按文件名字母序，知识脉络顺序 Phase 6 再做）
const allNotes = await getCollection('notes')
const topicNotes = allNotes
  .filter(n => n.id.startsWith(`${data.topic}/`) && !n.id.endsWith('/_overview'))
  .sort((a, b) => a.id.localeCompare(b.id))
const idx = topicNotes.findIndex(n => n.id === note.id)
const prev = idx > 0 ? topicNotes[idx - 1] : null
const next = idx >= 0 && idx < topicNotes.length - 1 ? topicNotes[idx + 1] : null

// 处理日期（可能是 Date 对象被 coerce 成 string）
const updated = data.updated ? String(data.updated).slice(0, 10) : ''
const tags = data.tags || []
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{data.title || note.id}</title>
</head>
<body>
  <header style="border-bottom: 1px solid #eee; padding: 12px 20px;">
    <a href={base}>← grounds</a>
  </header>

  <main style="max-width: 720px; margin: 40px auto; padding: 0 20px;">
    <h1>{data.title || note.id}</h1>
    <p style="color: #888; font-size: 0.85em; margin-bottom: 1em;">
      {data.topic}
      {updated && ` · ${updated}`}
      {tags.length > 0 && ` · ${tags.map(t => `#${t}`).join(' ')}`}
    </p>
    {data.summary && (
      <p style="background: #f5f5f5; padding: 12px 16px; border-radius: 4px; border-left: 3px solid #8b5cf6;">
        {data.summary}
      </p>
    )}

    <article>
      <Content />
    </article>

    <nav style="margin-top: 3em; padding-top: 1.5em; border-top: 1px solid #eee; display: flex; justify-content: space-between; gap: 20px;">
      {prev ? (
        <a href={`${base}/${prev.id}`}>← {prev.data.title}</a>
      ) : <span />}
      {next ? (
        <a href={`${base}/${next.id}`}>{next.data.title} →</a>
      ) : <span />}
    </nav>
  </main>
</body>
</html>
