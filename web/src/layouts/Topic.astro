---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Sidebar from '../components/Sidebar.astro'
import Search from '../components/Search.jsx'
import SidebarToggle from '../components/SidebarToggle.astro'
import '../styles/global.css'

interface Props {
  note: CollectionEntry<'notes'>  // _overview.md
}

const { note } = Astro.props
const { Content } = await render(note)
const topic = note.id.split('/')[0]
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const allNotes = await getCollection('notes')
const topicNotes = allNotes
  .filter(n => n.id.startsWith(`${topic}/`) && !n.id.endsWith('/_overview'))
  .sort((a, b) => String(b.data.updated || '').localeCompare(String(a.data.updated || '')))
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{note.data.title || `${topic} 总览`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
    <header class="site-header">
      <SidebarToggle />
      <a href={base}>← grounds</a>
      <span style="margin-left: 16px; color: var(--text-muted);">/</span>
      <a href={`${base}/tags`} style="margin-left: 8px;">标签</a>
    </header>

    <div class="note-layout note-layout--topic">
      <Sidebar currentTopic={topic} />

      <main class="note-main">
        <article data-pagefind-body>
          <Content />
        </article>

    <section class="home-section">
      <h2>笔记卡片</h2>
      <div class="note-grid">
        {topicNotes.map(n => (
          <a class="note-card" href={`${base}/${n.id}`}>
            <div class="note-title">{n.data.title || n.id}</div>
            {n.data.summary && (
              <div class="note-summary">{n.data.summary.slice(0, 80)}{n.data.summary.length > 80 ? '...' : ''}</div>
            )}
            {n.data.tags && n.data.tags.length > 0 && (
              <div class="note-tags">{n.data.tags.map(t => `#${t}`).join(' ')}</div>
            )}
          </a>
        ))}
      </div>
    </section>
      </main>
    </div>

  <Search client:idle />
</body>
</html>
