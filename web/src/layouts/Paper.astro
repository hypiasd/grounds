---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Sidebar from '../components/Sidebar.astro'
import Toc from '../components/Toc.astro'
import Search from '../components/Search.jsx'
import SidebarToggle from '../components/SidebarToggle.astro'
import '../styles/global.css'

interface Props {
  paper: CollectionEntry<'papers'>
}

const { paper } = Astro.props
const { Content, headings } = await render(paper)
const data = paper.data
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const paperBase = `${base}/paper`

const isOverview = paper.id.endsWith('/_overview')
const topic = paper.id.split('/')[0]

// 同 topic 内所有论文（按文件名字母序）
const allPapers = await getCollection('papers')
const topicPapers = allPapers
  .filter(p => p.id.startsWith(`${topic}/`) && !p.id.endsWith('/_overview'))
  .sort((a, b) => a.id.localeCompare(b.id))

// 单篇论文的 prev/next
const idx = isOverview ? -1 : topicPapers.findIndex(p => p.id === paper.id)
const prev = !isOverview && idx > 0 ? topicPapers[idx - 1] : null
const next = !isOverview && idx >= 0 && idx < topicPapers.length - 1 ? topicPapers[idx + 1] : null

const updated = data.updated ? String(data.updated).slice(0, 10) : ''
const tags = data.tags || []

function paperUrl(paperId: string): string {
  const isOv = paperId.endsWith('/_overview')
  const slug = isOv ? paperId.replace('/_overview', '') : paperId
  return `${paperBase}/${slug}`
}
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{data.title || paper.id}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+Pro:wght@400;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <SidebarToggle />
    <a href={base}>← grounds</a>
    <span style="margin-left: 16px; color: var(--text-muted);">/</span>
    <a href={`${paperBase}`} style="margin-left: 8px;">paper</a>
    <span style="margin-left: 8px; color: var(--text-muted);">/</span>
    <a href={`${paperBase}/${topic}`} style="margin-left: 8px;">{topic}</a>
  </header>

  {isOverview ? (
    <div class="note-layout note-layout--topic">
      <Sidebar currentTopic={topic} section="paper" />

      <main class="note-main">
        <article data-pagefind-body>
          <Content />
        </article>

        <section class="home-section">
          <h2>论文卡片</h2>
          <div class="note-grid">
            {topicPapers.map(p => (
              <a class="note-card" href={paperUrl(p.id)}>
                <div class="note-title">{p.data.title || p.id}</div>
                {p.data.summary && (
                  <div class="note-summary">{p.data.summary.slice(0, 80)}{p.data.summary.length > 80 ? '...' : ''}</div>
                )}
                {p.data.tags && p.data.tags.length > 0 && (
                  <div class="note-tags">{p.data.tags.map(t => `#${t}`).join(' ')}</div>
                )}
              </a>
            ))}
          </div>
        </section>
      </main>
    </div>
  ) : (
    <div class="note-layout">
      <Sidebar currentSlug={paper.id} currentTopic={data.topic} section="paper" />

      <main class="note-main">
        <h1>{data.title || paper.id}</h1>
        <div class="note-meta">
          {data.topic}
          {updated && ` · ${updated}`}
          {tags.map(t => <span class="tag">#{t}</span>)}
        </div>
        {data.summary && <div class="note-summary">{data.summary}</div>}

        <article data-pagefind-body>
          <Content />
        </article>

        <nav class="prev-next">
          {prev ? <a href={paperUrl(prev.id)}>← {prev.data.title}</a> : <span />}
          {next ? <a href={paperUrl(next.id)}>{next.data.title} →</a> : <span />}
        </nav>
      </main>

      <aside class="note-right">
        <Toc headings={headings} />
      </aside>
    </div>
  )}

  <Search client:idle />
</body>
</html>
