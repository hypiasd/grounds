---
import Graph from './Graph.jsx'
import { buildGraph } from '../data/graph'

interface Props {
  currentSlug?: string
  mini?: boolean
  height?: number
}

const { currentSlug, mini = false, height = 400 } = Astro.props
const graph = await buildGraph()
---
<Graph client:load data={graph} currentSlug={currentSlug} mini={mini} height={height} />
