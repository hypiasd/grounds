---
interface Props {
  headings: Array<{ depth: number; text: string; slug: string }>
}

const { headings } = Astro.props
// 只取 ## 和 ###（depth 2/3）
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3)
---
{tocItems.length > 0 && (
  <div class="toc">
    <h3>本页目录</h3>
    <ul>
      {tocItems.map(item => (
        <li class={item.depth === 3 ? 'toc-h3' : ''}>
          <a href={`#${item.slug}`}>{item.text}</a>
        </li>
      ))}
    </ul>
  </div>
)}
