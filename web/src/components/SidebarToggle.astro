---
// 浮动展开按钮（sidebar 折叠时显示）+ 折叠/展开持久化逻辑
// sidebar 内的折叠按钮在 Sidebar.astro 里，class 为 .sidebar-toggle--collapse
---
<button class="sidebar-toggle sidebar-toggle--floating" aria-label="展开侧边栏" title="展开侧边栏">»</button>

<script is:inline>
  (function () {
    const KEY = 'grounds:sidebar-hidden'
    const apply = (hidden) => {
      document.body.classList.toggle('sidebar-hidden', hidden)
      try { localStorage.setItem(KEY, hidden ? '1' : '0') } catch (e) {}
    }
    // 初始状态（防止 SSR 闪烁：尽早读取）
    const saved = (() => { try { return localStorage.getItem(KEY) } catch (e) { return null } })()
    if (saved === '1') apply(true)

    const toggle = () => apply(!document.body.classList.contains('sidebar-hidden'))

    document.addEventListener('DOMContentLoaded', () => {
      // 浮动展开按钮
      document.querySelectorAll('.sidebar-toggle--floating').forEach(btn => {
        btn.addEventListener('click', toggle)
      })
      // sidebar 内的折叠按钮
      document.querySelectorAll('.sidebar-toggle--collapse').forEach(btn => {
        btn.addEventListener('click', toggle)
      })
    })
  })()
</script>
