---
// 左侧边栏折叠按钮 + 持久化逻辑
---
<button id="sidebar-toggle" class="sidebar-toggle" aria-label="切换侧边栏" title="切换侧边栏">
  <span class="icon-sidebar-hide">»</span>
  <span class="icon-sidebar-show">«</span>
</button>

<script is:inline>
  (function () {
    const KEY = 'grounds:sidebar-hidden'
    const apply = (hidden) => {
      document.body.classList.toggle('sidebar-hidden', hidden)
      try { localStorage.setItem(KEY, hidden ? '1' : '0') } catch (e) {}
    }
    // 初始状态（防止 SSR 闪烁：尽早读取）
    const saved = (() => { try { return localStorage.getItem(KEY) } catch (e) { return null } })()
    if (saved === '1') apply(true)

    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('sidebar-toggle')
      if (!btn) return
      btn.addEventListener('click', () => {
        apply(!document.body.classList.contains('sidebar-hidden'))
      })
    })
  })()
</script>
