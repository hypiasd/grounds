---
import { getCollection } from 'astro:content'

interface Props {
  currentSlug?: string
  currentTopic?: string
  section?: 'wiki' | 'paper' | 'video'
}

const { currentSlug, currentTopic, section = 'wiki' } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// 分区入口 URL
const sectionLinks = [
  { key: 'wiki', label: 'wiki', href: base },
  { key: 'paper', label: 'paper', href: `${base}/paper` },
  { key: 'video', label: 'video', href: `${base}/video` },
] as const

// 根据 section 决定 URL 前缀和 collection
const sectionBase = section === 'wiki' ? base : `${base}/${section}`

function entryUrl(id: string): string {
  const isOverview = id.endsWith('/_overview')
  const slug = isOverview ? id.replace('/_overview', '') : id
  return `${sectionBase}/${slug}`
}

// 加载对应 collection
type Entry = { id: string; title?: string; topic?: string }
let entries: Entry[] = []

if (section === 'wiki') {
  const notes = await getCollection('notes')
  entries = notes.map(n => ({ id: n.id, title: n.data.title, topic: n.data.topic }))
} else if (section === 'paper') {
  const papers = await getCollection('papers')
  entries = papers.map(p => ({ id: p.id, title: p.data.title, topic: p.data.topic }))
} else if (section === 'video') {
  const videos = await getCollection('videos')
  // video 按目录名分组，每个目录取第一个 .md
  const videoMap = new Map<string, Entry>()
  for (const v of videos) {
    const slug = v.id.split('/')[0]
    if (!videoMap.has(slug)) {
      videoMap.set(slug, { id: slug, title: v.data.title, topic: 'video' })
    }
  }
  entries = [...videoMap.values()]
}
---
<aside class="sidebar">
  {/* 分区导航 */}
  <nav class="sidebar-sections">
    {sectionLinks.map(s => (
      <a
        href={s.href}
        class={`section-link ${s.key === section ? 'active' : ''}`}
      >
        {s.label}
      </a>
    ))}
  </nav>

  {/* wiki/paper：按 topic 分组 */}
  {section !== 'video' && (() => {
    const topics = new Map<string, Entry[]>()
    for (const entry of entries) {
      const topic = entry.id.split('/')[0]
      if (!topics.has(topic)) topics.set(topic, [])
      topics.get(topic)!.push(entry)
    }
    return [...topics.entries()].map(([topic, topicEntries]) => {
      const overview = topicEntries.find(e => e.id.endsWith('/_overview'))
      const items = topicEntries
        .filter(e => !e.id.endsWith('/_overview'))
        .sort((a, b) => a.id.localeCompare(b.id))
      const isCurrentTopic = topic === currentTopic
      return (
        <div class={`topic-group ${isCurrentTopic ? 'expanded' : ''}`}>
          <a class="topic-link" href={overview ? entryUrl(overview.id) : '#'}>
            {topic}
          </a>
          {isCurrentTopic && (
            <ul class="note-list">
              {items.map(item => (
                <li class={item.id === currentSlug ? 'current' : ''}>
                  <a href={entryUrl(item.id)}>{item.title || item.id}</a>
                </li>
              ))}
            </ul>
          )}
        </div>
      )
    })
  })()}

  {/* video：直接列出 */}
  {section === 'video' && (
    <ul class="note-list video-list">
      {entries
        .sort((a, b) => (a.title || '').localeCompare(b.title || ''))
        .map(item => (
          <li class={item.id === currentSlug ? 'current' : ''}>
            <a href={entryUrl(item.id)}>{item.title || item.id}</a>
          </li>
        ))}
    </ul>
  )}
</aside>

<style>
  .sidebar-sections {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .section-link {
    flex: 1;
    text-align: center;
    padding: 6px 8px;
    font-size: 13px;
    font-family: var(--font-heading);
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.15s;
  }
  .section-link:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
  }
  .section-link.active {
    color: var(--accent);
    background: var(--accent-soft);
    font-weight: 600;
  }
  .video-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .video-list li {
    padding: 4px 0;
  }
  .video-list li a {
    display: block;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.5;
  }
  .video-list li a:hover {
    color: var(--accent);
  }
  .video-list li.current a {
    color: var(--accent);
    font-weight: 600;
  }
</style>
