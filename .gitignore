# .gitignore

# 临时 / 缓存
.DS_Store
*.swp
*~
.cache/

# 依赖（若未来引入校验脚本）
node_modules/
__pycache__/
*.pyc

# 原始资料：PDF / 源码快照 / 视频 / 字幕等大文件只留本地，全部不进 git
# raw/ 目录会在 learn / paper-learn / video skill 使用时自动创建，无需 .gitkeep 维持骨架
raw/

# 项目目录：每个 project/<name>/ 是独立 git 仓库（或指向外部目录的软链），父仓库不跟踪其内部
project/*

# video 成品目录：只追踪 .md；.tex/.pdf 及其他中间产物全部不进 git
video/**/*.tex
video/**/*.pdf
video/**/sources/
video/**/figures/
video/**/ocr/
video/**/*.wav
video/**/*.mp4
video/**/*.srt
video/**/*.aux
video/**/*.log
video/**/*.out
video/**/*.toc
video/**/cover.jpg
video/**/*transcribe*.py
video/**/test_*.mp3
video/**/audio_compressed.mp3
video/**/_chunk_*.mp3
video/**/part*.tex
.playwright-cli/

# Quartz 前端（quartz/）
quartz/node_modules/
quartz/public/
quartz/.quartz/
.superpowers/
zhihu-articles/
